project_id        = "your-project-id"
region            = "us-central1"
superadmin_email  = "superadmin@yourdomain.com"

# Optional: suffix for Terraform-managed resource names (default: "tf")
# deployment_name_suffix = "tf"

# Firebase values are used by dashboard.
firebase_project_id  = "your-project-id"
firebase_auth_domain = "your-project-id.firebaseapp.com"
firebase_api_key     = "replace-me"
firebase_app_id      = "replace-me"

# Optional: set image tags published via gcp/infrastructure/docker scripts.
# management_image_version = "1.0.0"
# states_image_version     = "1.0.0"
# dashboard_image_version  = "1.0.0"

# Set to 0 to disable flag state cache (this can overwhelm the DB connection pool under heavy load)
# Set to 1 for tests
# Set to positive value (in seconds) for production
states_cache_ttl    = 1