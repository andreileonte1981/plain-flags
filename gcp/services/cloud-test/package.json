{
  "name": "plainflags-cloud-test",
  "version": "1.0.0",
  "description": "Cloud-deployable test service for Plain Flags management API",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "compile": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "test:local": "npm run compile && node dist/service-tests/run-local.js",
    "predeploy": "npm run compile"
  },
  "dependencies": {
    "fastify": "^5.1.0",
    "axios": "^1.8.3",
    "dotenv": "^16.4.5",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.3.0"
  },
  "author": "Andrei Leonte",
  "license": "ISC"
}
