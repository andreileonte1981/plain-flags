{
  "name": "plainflags-management-gcp",
  "version": "1.0.0",
  "description": "Plain Flags management service for Google Cloud",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "watch": "tsc --watch",
    "compile": "rm -rf dist && tsc",
    "start": "node -r dotenv/config dist/index.js",
    "dev": "env-cmd -f .env node --inspect=9229 --watch dist/index.js",
    "dev:start": "node -r dotenv/config dist/index.js",
    "predeploy": "npm run compile"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@google-cloud/cloud-sql-connector": "^1.3.2",
    "dotenv": "^16.6.1",
    "env-cmd": "^11.0.0",
    "fastify": "^5.1.0",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.2",
    "pg": "^8.14.1",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.27",
    "typeorm-naming-strategies": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.3"
  },
  "author": "Andrei Leonte",
  "license": "ISC"
}
