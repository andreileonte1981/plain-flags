# Plain Flags Management Service - Local Development Environment Variables

# Server Configuration
PORT=8080
NODE_ENV=development

# Cloud SQL Configuration
# Get this from: cat ../../infrastructure/.db-connection-name
DB_CONNECTION_NAME=project-name:zone:sql-instance-name
DB_NAME=plainflags
DB_USER=plainflags

# Database Password
DB_PASSWORD=

# Firebase / GCP project
FIREBASE_PROJECT_ID=

SUPERADMIN_EMAIL=

# Email of the test service account allowed to set the time offset (non-production only)
TEST_SERVICE_EMAIL=

DASHBOARD_PASSKEY=