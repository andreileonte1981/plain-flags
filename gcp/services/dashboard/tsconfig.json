{
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".react-router/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ],
    "compilerOptions": {
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES6"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "rootDirs": [
            ".",
            ".react-router/types"
        ],
        "paths": {
            "~/*": [
                "./app/*"
            ]
        },
        "target": "ES2022",
        "module": "ESNext"
    }
}